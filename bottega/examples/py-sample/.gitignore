.venv/
__pycache__/
.pytest_cache/
*.pyc
# lockfiles generated during testing — never commit
uv.lock
poetry.lock
Pipfile.lock

# bottega runtime scratch (registry, worktrees, APS binaries, pinned venv) — never
# committed — but the pinned APS lock IS tracked (a whole-dir ignore can't re-include
# a child, so ignore the contents and negate the lock).
.bottega/*
!.bottega/aps.lock
